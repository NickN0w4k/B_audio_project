{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "B Audio Project",
  "version": "0.1.0",
  "identifier": "com.nick.baudioproject",
  "build": {
    "beforeDevCommand": "npm run dev --workspace desktop-ui",
    "beforeBuildCommand": "npm run build --workspace desktop-ui",
    "frontendDist": "../apps/desktop-ui/dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "B Audio Project",
        "width": 1440,
        "height": 960,
        "resizable": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$APPLOCALDATA/**"
        ]
      },
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": [],
    "icon": []
  }
}
